# MongoDB
MONGODB_URI=mongodb://localhost:27017
DB_NAME=ip_group

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRE_MINUTES=60

# FastAPI
ROOT_PATH=

# CORS — comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000

# Cloudflare Turnstile (from dashboard.cloudflare.com/turnstile)
TURNSTILE_SECRET_KEY=replace-with-your-turnstile-secret-key

# SMTP (Gmail App Password: myaccount.google.com/apppasswords)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=you@gmail.com
SMTP_PASSWORD=replace-with-app-password
SMTP_FROM=you@gmail.com
RESET_TOKEN_EXPIRE_MINUTES=15

# OpenRouter (openrouter.ai/keys)
OPENROUTER_API_KEY=replace-with-your-openrouter-api-key
OPENROUTER_TIMEOUT=60.0
